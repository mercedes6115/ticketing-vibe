{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "title": "Overview",
      "type": "row"
    },
    {
      "title": "HTTP Request Rate (TPS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"ticketing\"}[1m]))",
          "legendFormat": "Total TPS"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"ticketing\", uri=~\"/api/bookings.*\"}[1m]))",
          "legendFormat": "Bookings"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"ticketing\", uri=~\"/api/seats.*\"}[1m]))",
          "legendFormat": "Seats"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"ticketing\", uri=~\"/api/queue.*\"}[1m]))",
          "legendFormat": "Queue"
        }
      ]
    },
    {
      "title": "Response Time (p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 5, "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"ticketing\"}[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"ticketing\"}[1m])) by (le))",
          "legendFormat": "p99"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{application=\"ticketing\"}[1m])) by (le))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "title": "HTTP Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"ticketing\", status=~\"4..\"}[1m]))",
          "legendFormat": "4xx"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"ticketing\", status=~\"5..\"}[1m]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "title": "Endpoints",
      "type": "row"
    },
    {
      "title": "Endpoint Response Time (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 5, "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"ticketing\", uri=\"/api/bookings\", method=\"POST\"}[1m])) by (le))",
          "legendFormat": "POST /bookings"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"ticketing\", uri=~\"/api/seats/.*/hold\"}[1m])) by (le))",
          "legendFormat": "POST /seats/hold"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"ticketing\", uri=\"/api/queue/enter\", method=\"POST\"}[1m])) by (le))",
          "legendFormat": "POST /queue/enter"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"ticketing\", uri=\"/api/queue/token\", method=\"POST\"}[1m])) by (le))",
          "legendFormat": "POST /queue/token"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"ticketing\", uri=~\"/api/bookings/status/.*\"}[1m])) by (le))",
          "legendFormat": "GET /bookings/status"
        }
      ]
    },
    {
      "title": "Endpoint TPS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"ticketing\", uri=\"/api/bookings\", method=\"POST\"}[1m]))",
          "legendFormat": "POST /bookings"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"ticketing\", uri=~\"/api/seats/.*/hold\"}[1m]))",
          "legendFormat": "POST /seats/hold"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"ticketing\", uri=\"/api/queue/enter\", method=\"POST\"}[1m]))",
          "legendFormat": "POST /queue/enter"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"ticketing\", uri=~\"/api/bookings/status/.*\"}[1m]))",
          "legendFormat": "GET /bookings/status"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "title": "Infrastructure",
      "type": "row"
    },
    {
      "title": "HikariCP Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"ticketing\"}",
          "legendFormat": "Active"
        },
        {
          "expr": "hikaricp_connections_idle{application=\"ticketing\"}",
          "legendFormat": "Idle"
        },
        {
          "expr": "hikaricp_connections_pending{application=\"ticketing\"}",
          "legendFormat": "Pending"
        },
        {
          "expr": "hikaricp_connections_max{application=\"ticketing\"}",
          "legendFormat": "Max"
        }
      ]
    },
    {
      "title": "Kafka Consumer Records / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(kafka_consumer_fetch_manager_records_consumed_total{application=\"ticketing\"}[1m]))",
          "legendFormat": "Records consumed/s"
        },
        {
          "expr": "sum(kafka_consumer_fetch_manager_records_lag_max{application=\"ticketing\"})",
          "legendFormat": "Consumer lag (max)"
        }
      ]
    },
    {
      "title": "Active HTTP Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "tomcat_threads_busy_threads{application=\"ticketing\"}",
          "legendFormat": "Busy threads"
        },
        {
          "expr": "tomcat_threads_current_threads{application=\"ticketing\"}",
          "legendFormat": "Current threads"
        },
        {
          "expr": "tomcat_threads_config_max_threads{application=\"ticketing\"}",
          "legendFormat": "Max threads"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "title": "JVM",
      "type": "row"
    },
    {
      "title": "JVM Heap Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{application=\"ticketing\", area=\"heap\"})",
          "legendFormat": "Used"
        },
        {
          "expr": "sum(jvm_memory_max_bytes{application=\"ticketing\", area=\"heap\"})",
          "legendFormat": "Max"
        },
        {
          "expr": "sum(jvm_memory_committed_bytes{application=\"ticketing\", area=\"heap\"})",
          "legendFormat": "Committed"
        }
      ]
    },
    {
      "title": "GC Pause Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"ticketing\"}[1m])",
          "legendFormat": "{{action}} - {{cause}}"
        }
      ]
    },
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "unit": "percentunit",
          "max": 1
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"ticketing\"}",
          "legendFormat": "Process CPU"
        },
        {
          "expr": "system_cpu_usage{application=\"ticketing\"}",
          "legendFormat": "System CPU"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["ticketing", "load-test"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 2,
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Ticketing Load Test",
  "uid": "ticketing-load-test"
}
